# Nginx Configuration for Exam Jingga - Main Application
#
# Installation:
# 1. Copy this file to /etc/nginx/sites-available/exam-jingga
# 2. Replace 'yourdomain.com' with your actual domain
# 3. Create symlink: ln -s /etc/nginx/sites-available/exam-jingga /etc/nginx/sites-enabled/
# 4. Test config: nginx -t
# 5. Reload Nginx: systemctl reload nginx
# 6. Setup SSL: certbot --nginx -d yourdomain.com -d www.yourdomain.com

server {
    listen 80;
    listen [::]:80;

    # GANTI DENGAN DOMAIN ANDA
    server_name yourdomain.com www.yourdomain.com;

    # Root directory - lokasi file build aplikasi
    root /var/www/exam-jingga/dist;
    index index.html;

    # Gzip compression untuk mempercepat loading
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied expired no-cache no-store private auth;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/json application/xml+rss;
    gzip_disable "MSIE [1-6]\.";

    # Main location - SPA routing
    # Semua request akan di-redirect ke index.html (React Router)
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Cache static assets untuk performa
    location ~* \.(jpg|jpeg|png|gif|ico|svg|webp)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    location ~* \.(css|js)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    location ~* \.(woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;

    # Disable access to hidden files (.git, .env, etc)
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # Logs
    access_log /var/log/nginx/exam-jingga-access.log;
    error_log /var/log/nginx/exam-jingga-error.log;

    # Max upload size (jika ada upload file di aplikasi)
    client_max_body_size 10M;
}

# Setelah setup SSL dengan Certbot, Nginx akan otomatis menambahkan
# server block untuk HTTPS (port 443) di bawah ini
